rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /game_sessions/{sessionId} {
      allow create: if true;
      allow read, update, delete: if request.auth.uid == resource.data.user_id;
    }

    match /game_sessions/{sessionId}/attempts/{attemptId} {
      allow create: if true;
      allow read, update, delete: if request.auth.uid == resource.data.user_id;
    }

    match /game_sessions/{sessionId}/events/{eventId} {
      allow create: if true;
      allow read, update, delete: if request.auth.uid == resource.data.user_id;
    }

    match /leaderboards/{stageId}/versions/{versionId}/entries/{playerId} {
      allow read: if request.auth != null
        && (request.query == null || request.query.limit == null || request.query.limit <= 250);
      allow create: if request.auth != null
        && request.resource.data.player_id == playerId
        && request.resource.data.auth_uid == request.auth.uid;
      allow update: if request.auth != null
        && request.resource.data.player_id == playerId
        && request.resource.data.auth_uid == request.auth.uid
        && (resource.data.auth_uid == null || resource.data.auth_uid == request.auth.uid);
      allow delete: if false;
    }

    match /leaderboards_global/progress/entries/{playerId} {
      allow read: if request.auth != null
        && (request.query == null || request.query.limit == null || request.query.limit <= 250);
      allow create: if request.auth != null
        && request.resource.data.player_id == playerId
        && request.resource.data.auth_uid == request.auth.uid;
      allow update: if request.auth != null
        && request.resource.data.player_id == playerId
        && request.resource.data.auth_uid == request.auth.uid
        && (resource.data.auth_uid == null || resource.data.auth_uid == request.auth.uid);
      allow delete: if false;
    }
    
    match /leaderboards/{stageId}/versions/{versionId}/metadata {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
